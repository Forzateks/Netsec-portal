      "type": "action",
      "owner": "Presales / Sr. Consultant",
      "ownerIds": ["darays-dodi", "venkatesan"],
      "description": "Presales reviews the RFP requirements and validates feasibility against Gulfit's networking portfolio.",
      "artifacts": [],
      "nextStages": ["match-decision"]
    },
    {
      "id": "match-decision",
      "label": "RFP Match to Portfolio?",
      "type": "decision",
      "owner": "",
      "ownerIds": [],
      "description": "Decision point: does the RFP align with Gulfit's networking portfolio capabilities?",
      "artifacts": [],
      "branches": [
        { "label": "Yes — in scope", "to": "prepare-response" },
        { "label": "No — outside scope", "to": "return-to-bdm" }
      ],
      "nextStages": ["prepare-response", "return-to-bdm"]
    },
    {
      "id": "return-to-bdm",
      "label": "Return RFP to BDM",
      "type": "terminal",
      "owner": "Presales",
      "ownerIds": ["darays-dodi"],
      "description": "RFP doesn't match — sent back to BDM with a written explanation of the gaps.",
      "artifacts": ["Gap Analysis Note"],
      "nextStages": []
    },
    {
      "id": "prepare-response",
      "label": "Prepare Response Documents",
      "type": "action",
      "owner": "Presales / Sr. Consultant",
      "ownerIds": ["darays-dodi", "venkatesan"],
      "description": "Build the full RFP response package: technical proposal, architecture, BoM, SoW, and initial implementation tracker.",
      "artifacts": [
        "RFP Response Document",
        "Technical Proposal (Doc & PPT)",
        "Proposed Architecture Diagram",
        "Bill of Materials (BoM)",
        "Statement of Work (SoW)",
        "Implementation Tracker (initial)"
      ],
      "nextStages": ["consultant-review"]
    },
    {
      "id": "consultant-review",
      "label": "Sr. Consultant Review",
